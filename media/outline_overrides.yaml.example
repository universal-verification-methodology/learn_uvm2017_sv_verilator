# Copy to {course}/media/outline_overrides.yaml
# Used by generate_outline_from_module.py to fix demos that need git repos,
# scaffolds, or non-interactive capture commands.
#
# Keys: module number → demos → example folder name (from EXAMPLES.md)

module6:
  demos:
    init_clone:
      command: "./scripts/module6.sh --scaffold 2>/dev/null; cd ~/unix_practice/git_demo && git status"
      expect: "git"

module7:
  demos:
    conflicts:
      command: "head -15 module7/examples/conflicts/sample_conflict.txt"
      expect: "<<<<<<<"

module8:
  demos:
    submission:
      command: "head -12 module8/examples/submission/README.md"
      expect: "submit"
